{
  "title": "ALABA AL SEÑOR",
  "category": "Entrada",
  "ritmo": "4/4",
  "cejilla": 0,
  "originalKey": "DO",

  "lines": [
    {
      "chordLine" : "DO              lam",
      "lyrics"    : "Alaba al Señor alma mía,"
    },
    {
      "chordLine" : "     FA      rem       SOL",
      "lyrics"    : "glorifica su nombre también,"
    },
    {
      "chordLine" : "          mim                 lam       FA",
      "lyrics"    : "porque la gloria del Señor es mía por siempre,"
    },
    {
      "chordLine" : "  DO                  SOL",
      "lyrics"    : "Jesús es el mismo de ayer."
    },
    {
      "chordLine" : "     lam              DO",
      "lyrics"    : "El Señor me libró, mi vida cambió,"
    },
    {
      "chordLine" : "  FA      rem        SOL",
      "lyrics"    : "y todo el mundo lo verá,"
    },
    {
      "chordLine" : "          mim                lam        FA",
      "lyrics"    : "porque el vino que me dio alegró mi corazón"
    },
    {
      "chordLine" : "          DO       SOL     DO",
      "lyrics"    : "y con su aceite mi cara brilló."
    }
  ]
}
